# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Project specific
*.log
.env
config.json

# Runtime data (keep directory structure via .gitkeep)
data/cache/*
data/logs/*
data/temp/*
!data/cache/.gitkeep
!data/logs/.gitkeep
!data/temp/.gitkeep

# User vaults (local note storage)
user_vaults/*
!user_vaults/.gitkeep